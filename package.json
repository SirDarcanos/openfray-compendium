{
  "name": "openfray-compendium",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Compendium data-generation tooling for OpenFray — ingests SRD and third-party sources into OpenFray's Creature schema, validates the output, and emits the JSON the app ships.",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "ingest:srd-2014": "node scripts/ingest-srd-2014.ts",
    "ingest:srd52": "node scripts/ingest-srd52.ts",
    "ingest:srd52-spells": "node scripts/ingest-srd52-spells.ts",
    "validate": "node scripts/validate-compendium.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.7.2",
    "vitest": "^3.0.0"
  }
}
